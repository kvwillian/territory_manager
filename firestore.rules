rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: get current user's congregationId from users collection.
    // Use exists() before get() to avoid null evaluation when doc is missing
    // (e.g. right after Cloud Function creates user, before propagation).
    function userCongregationId() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path)
        && get(path).data != null
        && get(path).data.congregationId != null
        ? get(path).data.congregationId
        : 'default';
    }

    // Helper: resource belongs to user's congregation (or has no congregationId for backward compat)
    // Use 'is string' to avoid type mismatch (e.g. if congregationId was stored as number)
    function resourceInUserCongregation(resource) {
      let cid = resource.data.congregationId;
      let resourceCid = (cid != null && cid is string && cid != '')
        ? cid
        : 'default';
      return resourceCid == userCongregationId();
    }

    match /congregations/{congregationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /territories/{territoryId} {
      allow read, update, delete: if request.auth != null
        && resourceInUserCongregation(resource);
      allow create: if request.auth != null
        && (request.resource.data.congregationId == userCongregationId()
            || request.resource.data.congregationId == null);
    }

    match /segments/{segmentId} {
      allow read, update, delete: if request.auth != null
        && resourceInUserCongregation(resource);
      allow create: if request.auth != null
        && (request.resource.data.congregationId == userCongregationId()
            || request.resource.data.congregationId == null);
    }

    match /users/{userId} {
      allow read: if request.auth != null
        && (userId == request.auth.uid
            || resource.data.congregationId == userCongregationId()
            || (resource.data.congregationId == null && userCongregationId() == 'default'));
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (userId == request.auth.uid
            || resourceInUserCongregation(resource));
    }

    match /assignments/{assignmentId} {
      // TEMP: relaxed for debugging - allow all auth'd read/write (like /congregations)
      allow read, write: if request.auth != null;
    }

    match /workSessions/{sessionId} {
      allow read, update, delete: if request.auth != null
        && resourceInUserCongregation(resource);
      allow create: if request.auth != null
        && (request.resource.data.congregationId == userCongregationId()
            || request.resource.data.congregationId == null);
    }

    match /neighborhoods/{neighborhoodId} {
      allow read, update, delete: if request.auth != null
        && resourceInUserCongregation(resource);
      allow create: if request.auth != null
        && (request.resource.data.congregationId == userCongregationId()
            || request.resource.data.congregationId == null);
    }

    match /meetingLocations/{locationId} {
      allow read, update, delete: if request.auth != null
        && resourceInUserCongregation(resource);
      allow create: if request.auth != null
        && (request.resource.data.congregationId == userCongregationId()
            || request.resource.data.congregationId == null);
    }

    match /preachingSessions/{sessionId} {
      allow read, update, delete: if request.auth != null
        && resourceInUserCongregation(resource);
      allow create: if request.auth != null
        && (request.resource.data.congregationId == userCongregationId()
            || request.resource.data.congregationId == null);
    }
  }
}
